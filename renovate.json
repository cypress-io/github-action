{
  "configMigration": true,
  "extends": [
    "config:recommended"
  ],
  "automerge": true,
  "major": {
    "automerge": false
  },
  "labels": [
    "type: dependencies",
    "renovate"
  ],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 1,
  "packageRules": [
    {
      "matchDepTypes": ["dependencies"],
      "enabled": false
    },
    {
      "matchPackageNames": [
        "/eslint/",
        "globals"
      ],
      "groupName": "eslint",
      "extends": ["schedule:monthly"]
    },
    {
      "matchPackageNames": ["@types/node"],
      "extends": ["schedule:quarterly"]
    }
  ]
}
